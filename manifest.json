{
  "manifest_version": 3,
  "name": "GlossaPop",
  "version": "1.0.5",
  "description": "Floating translation popup for English and French. Supports audio, IPA phonetics, and bilingual explanation toggles.",
  "permissions": [
    "storage",
    "activeTab",
    "identity"
  ],
  "host_permissions": [
    "https://api.dictionaryapi.dev/api/v2/entries/en/*",
    "https://lingva.ml/api/v1/*",
    "https://translate.googleapis.com/*",
    "https://sheets.googleapis.com/v4/spreadsheets*",
    "https://www.googleapis.com/drive/v3/files*"
  ],
  "oauth2": {
    "client_id": "213944880893-ej291f9246dm8rpc0l8jt20il2akmiak.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils.js",
        "audio.js",
        "ui.js",
        "settings.js",
        "events.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/logo-cat.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}

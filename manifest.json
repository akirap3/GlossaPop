{
  "manifest_version": 3,
  "name": "GlossaPop",
  "version": "1.0.4",
  "description": "Floating translation popup for English and French. Supports audio, IPA phonetics, and bilingual explanation toggles.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.dictionaryapi.dev/api/v2/entries/en/*",
    "https://lingva.ml/api/v1/*",
    "https://translate.googleapis.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils.js",
        "audio.js",
        "ui.js",
        "settings.js",
        "events.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/logo-cat.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
